</edge>
<edge source="VecPAC" target="HEAL-WEAR">
  <data key="d7">1.0</data>
  <data key="d8">Both VecPAC and HEAL-WEAR aim to support vector computations but target different application domains.</data>
  <data key="d9">architectural inspiration,comparison</data>
  <data key="d10">chunk-709227a765c55f9d3440bf6ca2a72a60</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1766322539</data>
  <data key="d13"></data>
</edge>
<edge source="VecPAC" target="Riken">
  <data key="d7">1.0</data>
  <data key="d8">VecPAC and Riken both focus on optimizing CGRA designs but target different application domains and have distinct architectures.</data>
  <data key="d9">architectural inspiration,comparison</data>
  <data key="d10">chunk-709227a765c55f9d3440bf6ca2a72a60</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1766322540</data>
