  <data key="d11">unknown_source</data>
  <data key="d12">1766322540</data>
  <data key="d13"></data>
</edge>
<edge source="VecPAC" target="SPM">
  <data key="d7">1.0</data>
  <data key="d8">SPM can perform memory operations, while on VecPAC only half of these can perform vectorized memory accesses.</data>
