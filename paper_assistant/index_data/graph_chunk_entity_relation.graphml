  <data key="d3">chunk-867038b972ebe25908221a61e9ba9a9c</data>
  <data key="d2">The DFG is mapped onto the MRRG targeting minimum II as the objective for efficient utilization of hardware resources.</data>
  <data key="d1">UNKNOWN</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1766322531</data>
  <data key="d6"></data>
</node>
<node id="DFG Tuning">
  <data key="d0">DFG Tuning</data>
  <data key="d3">chunk-867038b972ebe25908221a61e9ba9a9c</data>
  <data key="d2">Our framework implements a heuristic optimization algorithm that tunes the DFG before mapping it onto the MRRG.</data>
  <data key="d1">UNKNOWN</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1766322531</data>
  <data key="d6"></data>
