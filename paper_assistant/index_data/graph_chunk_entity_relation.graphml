</edge>
<edge source="VecPAC" target="32-bit Fixed-Point Multiplication">
  <data key="d7">1.0</data>
  <data key="d8">The VecPAC framework supports 32-bit fixed-point multiplications by breaking them into multiple parallel 16-bit operations and appropriate shifts.</data>
  <data key="d9">arithmetic operation,framework support</data>
  <data key="d10">chunk-92e82cee01030c7760843fcd3f03ed32</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1766322540</data>
  <data key="d13"></data>
</edge>
<edge source="VecPAC" target="16-bit Fixed-Point Multiplication">
  <data key="d7">1.0</data>
  <data key="d8">VecPAC supports 16-bit fixed-point multiplications as part of its vector multiplier capabilities.</data>
  <data key="d9">arithmetic operation,framework support</data>
  <data key="d10">chunk-92e82cee01030c7760843fcd3f03ed32</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1766322540</data>
