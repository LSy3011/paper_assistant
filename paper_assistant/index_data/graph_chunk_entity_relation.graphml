  <data key="d11">unknown_source</data>
  <data key="d12">1766322537</data>
  <data key="d13"></data>
</edge>
<edge source="Conv Kernel" target="SpMV">
  <data key="d7">1.0</data>
  <data key="d8">The SpMV kernel is an example of a non-vectorizable computational kernel.</data>
  <data key="d9">dependency issues,non-vectorizable kernels</data>
  <data key="d10">chunk-ece4f507673e067d1b26b4c5db6aaef9</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1766322537</data>
  <data key="d13"></data>
</edge>
<edge source="Conv Kernel" target="Histogram">
  <data key="d7">1.0</data>
  <data key="d8">Histogram operations are not vectorizable due to unsafe dependent memory operations.</data>
  <data key="d9">memory safety concerns,non-vectorizable kernels</data>
  <data key="d10">chunk-ece4f507673e067d1b26b4c5db6aaef9</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1766322537</data>
  <data key="d13"></data>
</edge>
<edge source="Speedup" target="VecPAC Architecture">
  <data key="d7">1.0</data>
  <data key="d8">The VecPAC architecture can achieve higher speedups with a hybrid design of scalar and vector tiles.</data>
  <data key="d9">performance improvement,resource exploitation</data>
  <data key="d10">chunk-ece4f507673e067d1b26b4c5db6aaef9</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1766322537</data>
  <data key="d13"></data>
</edge>
<edge source="Accuracy" target="VecPAC Architecture">
  <data key="d7">1.0</data>
  <data key="d8">The accuracy of computation can be traded for performance or area efficiency in some applications.</data>
  <data key="d9">computation precision,trade-off consideration</data>
