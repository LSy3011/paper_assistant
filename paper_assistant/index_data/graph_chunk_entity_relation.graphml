<node id="Apply Optimizations">
  <data key="d0">Apply Optimizations</data>
  <data key="d1">method</data>
  <data key="d2">Applying optimizations is a set of transformations that include merging generics, converting linalg to loops, loop coalescing, and loop unrolling.</data>
  <data key="d3">chunk-6f7cad872120e96e22443543d20a47ae</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1766410742</data>
  <data key="d6"></data>
</node>
<node id="Merge Generics">
  <data key="d0">Merge Generics</data>
  <data key="d1">method</data>
  <data key="d2">Merging generics is part of the optimization process in MLIR.</data>
  <data key="d3">chunk-6f7cad872120e96e22443543d20a47ae</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1766410742</data>
  <data key="d6"></data>
</node>
<node id="Convert Linalg to Loops">
  <data key="d0">Convert Linalg to Loops</data>
  <data key="d1">method</data>
  <data key="d2">Converting linalg to loops is a transformation step that converts linear algebra operations into loop-based representations.</data>
  <data key="d3">chunk-6f7cad872120e96e22443543d20a47ae</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1766410742</data>
  <data key="d6"></data>
</node>
<node id="Loop Coalescing">
  <data key="d0">Loop Coalescing</data>
  <data key="d1">method</data>
  <data key="d2">Loop coalescing is a transformation step that combines multiple loops into fewer, more efficient ones.</data>
  <data key="d3">chunk-6f7cad872120e96e22443543d20a47ae</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1766410742</data>
  <data key="d6"></data>
</node>
<node id="Loop Unroll">
  <data key="d0">Loop Unroll</data>
  <data key="d1">method</data>
  <data key="d2">Loop unrolling is a transformation step that expands loop iterations to reduce overhead and improve performance.</data>
  <data key="d3">chunk-6f7cad872120e96e22443543d20a47ae</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1766410742</data>
  <data key="d6"></data>
</node>
<node id="MLIR Transformations">
  <data key="d0">MLIR Transformations</data>
  <data key="d1">method</data>
  <data key="d2">MLIR transformations are used to optimize operations in the MLIR dialect.</data>
  <data key="d3">chunk-6f7cad872120e96e22443543d20a47ae</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1766410742</data>
  <data key="d6"></data>
</node>
<node id="Protobuf File">
  <data key="d0">Protobuf File</data>
  <data key="d1">data</data>
