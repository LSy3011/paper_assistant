  <data key="d1">artifact</data>
  <data key="d2">These are advanced software components used in ML-CGRA to optimize data reuse and scalability.</data>
  <data key="d3">chunk-46c9950a6d7f273199820d455082eed4</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1766322486</data>
