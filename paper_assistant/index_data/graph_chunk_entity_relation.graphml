  <data key="d0">Gabriel Weisz</data>
  <data key="d1">person</data>
  <data key="d2">Gabriel Weisz works at Microsoft and contributes to the VecPAC project.</data>
  <data key="d3">chunk-709227a765c55f9d3440bf6ca2a72a60</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1766322524</data>
  <data key="d6"></data>
</node>
