</node>
<node id="ASAP 7nm FinFET Cell Library">
  <data key="d0">ASAP 7nm FinFET Cell Library</data>
  <data key="d1">artifact</data>
  <data key="d2">The ASAP 7nm FinFET cell library is used for generating GDSII from VecPAC's RTL.</data>
  <data key="d3">chunk-0e2dc42cf9d2604980f8a4ea00b9e5e9</data>
  <data key="d4">unknown_source</data>
