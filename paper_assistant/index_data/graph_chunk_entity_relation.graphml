  <data key="d11">unknown_source</data>
  <data key="d12">1766322537</data>
  <data key="d13"></data>
</edge>
<edge source="HEAL-WEAR" target="vector computations">
  <data key="d7">1.0</data>
  <data key="d8">HEAL-WEAR duplicates the data path in each tile to enable vector computations for ECG applications.</data>
