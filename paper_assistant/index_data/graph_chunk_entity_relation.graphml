  <data key="d13"></data>
</edge>
<edge source="VecPAC" target="Fixed-Point64 Vector FUs">
  <data key="d7">1.0</data>
  <data key="d8">Fixed-Point64 Vector FUs are part of the VecPAC architecture for precision awareness and dynamic trading off accuracy with vector units size.</data>
